def cmd_board(args):
    """选题看板：四列 / 单列过滤"""
    rows = request("/api/topics").get("topics", [])
    if not rows:
        print("（还没有选题——评估器每 6 小时跑一轮）")
        return

    # 过滤
    if args.status:
        rows = [t for t in rows if t.get("status") == args.status]
    if args.series:
        rows = [t for t in rows if t.get("series") == args.series]

    if args.json:
        print(json.dumps(rows, ensure_ascii=False))
        return

    if args.status or args.series:
        # 单列模式
        _print_topic_list(rows)
        return

    # 四列看板模式
    for status, label in BOARD_COLUMNS:
        col = [t for t in rows if t.get("status") == status]
        if not col:
            continue
        print(f"\n{'─' * 60}")
        print(f"{label}（{len(col)}）")
        print(f"{'─' * 60}")
        _print_topic_list(col, compact=True)
    print(f"\n共 {len(rows)} 条 · topics board --status <status> 单列过滤 · topics edit <id> 修改")


def _print_topic_list(rows, compact=False):
    for t in rows:
        sid = f"#{t['id']}"
        title = str(t.get("title", ""))[:40]
        extra_parts = []
        if t.get("platform"):
            extra_parts.append(t["platform"])
        if t.get("contentType"):
            extra_parts.append(t["contentType"])
        if t.get("series"):
            so = f"#{t.get('seriesOrder', '?')}" if t.get("seriesOrder") else ""
            extra_parts.append(f"{t['series']}{so}")
        if t.get("scheduledDate"):
            extra_parts.append(f"📅{t['scheduledDate'][:10]}")
        extra = " · ".join(extra_parts) if extra_parts else ""
        if compact:
            print(f"  {sid:<5} {title:<42} {extra}")
        else:
            print(f"  {sid:<5} {title}")
            if t.get("angle"):
                print(f"        角度: {t['angle']}")
            if extra:
                print(f"        {extra}")
            print()


