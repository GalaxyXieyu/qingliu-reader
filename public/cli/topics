def cmd_strategy(args):
    """策略查看 / 管理（平台策略、禁用词、CTA 模板等）"""
    sub = getattr(args, "sub", None)

    # --- versions: 版本历史 ---
    if sub == "versions":
        for v in request("/api/strategy/versions").get("versions", []):
            act = "← 当前" if v.get("isActive") else ""
            print(f"  v{v['version']}  {v.get('createdAt', '')[:16]}  {v.get('note') or ''} {act}")
        return

    # --- set: 上传新策略 ---
    if sub == "set":
        if not args.file:
            sys.exit("用法: topics strategy set --file strategy.json --note \"说明\"")
        content = Path(args.file).read_text()
        json.loads(content)  # 校验 JSON 合法
        note = args.note or "via cli"
        r = request("/api/strategy", "POST", {"content": content, "note": note})
        print(f"✅ 策略已保存为 v{r.get('version')} 并设为当前版本")
        return

    # --- activate: 回滚版本 ---
    if sub == "activate":
        if not args.version:
            sys.exit("用法: topics strategy activate <version>")
        r = request("/api/strategy/versions", "POST", {"version": int(args.version)})
        print(f"✅ 已激活策略 v{r.get('version')}（{r.get('note', '')}）")
        return

    # --- 默认: 查看策略 ---
    # 构造 query 参数
    params = []
    if args.platform:
        params.append(f"platform={args.platform}")
    if args.section:
        params.append(f"section={args.section}")
    qs = ("?" + "&".join(params)) if params else ""

    if args.cached:
        # 读本地缓存
        if not STRATEGY_CACHE.exists():
            sys.exit("没有本地缓存，先跑一次 topics strategy 拉取")
        data = json.loads(STRATEGY_CACHE.read_text())
    else:
        data = request(f"/api/strategy{qs}")
        # 完整拉取（无 platform/section 过滤）时缓存
        if not args.platform and not args.section:
            CONFIG_DIR.mkdir(parents=True, exist_ok=True)
            STRATEGY_CACHE.write_text(json.dumps(data, ensure_ascii=False, indent=2))

    # --json: 纯 JSON 输出（Skills 管道消费）
    if args.json:
        print(json.dumps(data.get("data", data), ensure_ascii=False))
        return

    # 人类可读输出
    version = data.get("version", "?")
    note = data.get("note", "")
    content = data.get("data", data)

    print(f"# 策略 v{version} · {note}")
    print()
    print(json.dumps(content, ensure_ascii=False, indent=2))


