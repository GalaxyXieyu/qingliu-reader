def cmd_update(args):
    """自更新 CLI 脚本"""
    script_path = Path(sys.argv[0]).resolve()
    if not script_path.exists():
        sys.exit(f"无法定位脚本路径: {script_path}")

    # 下载远程脚本
    url = f"{endpoint()}/cli/topics"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": f"topics-cli/{CLI_VERSION}"})
        with urllib.request.urlopen(req, timeout=30) as resp:
            remote_content = resp.read().decode()
    except Exception as e:
        sys.exit(f"下载失败: {e}")

    # 提取远程版本号
    m = re.search(r'CLI_VERSION\s*=\s*"([^"]+)"', remote_content)
    if not m:
        sys.exit("无法从远程脚本提取版本号")
    remote_ver = m.group(1)

    if args.check:
        if remote_ver == CLI_VERSION:
            print(f"✅ 已是最新版 v{CLI_VERSION}")
        else:
            print(f"本地: v{CLI_VERSION} → 远程: v{remote_ver}")
            print(f"运行 topics update 更新")
        return

    # 执行更新
    if remote_ver == CLI_VERSION:
        print(f"已是最新版 v{CLI_VERSION}，无需更新")
        return

    # 备份
    backup_path = script_path.parent / f"topics.backup-{CLI_VERSION}"
    backup_path.write_text(script_path.read_text())
    print(f"✅ 已备份到 {backup_path}")

    # 写入新内容
    script_path.write_text(remote_content)
    os.chmod(script_path, 0o755)
    print(f"✅ 已更新到 v{remote_ver}")
    print(f"   重新运行: topics version 确认")


